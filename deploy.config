# deploy.config — place this file at the root of each project repo
# Jenkinsfile reads this file as default values
# Jenkins Parameters will override if filled in when triggering manually

REPO_URL    = git@github.com:yourusername/project.git
BRANCH      = main
COMPOSE_DIR = infra
ENV_FILE_ID = pro.env
APP_PORT    = 8888
APP_NAME    = Example